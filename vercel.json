{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/viewer.html"
    },
    {
      "source": "/broadcaster",
      "destination": "/frontend/broadcaster.html"
    },
    {
      "source": "/viewer",
      "destination": "/frontend/viewer.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "cleanUrls": true
}