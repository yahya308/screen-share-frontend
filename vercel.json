{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/frontend/viewer.html"
    },
    {
      "src": "/broadcaster",
      "dest": "/frontend/broadcaster.html"
    },
    {
      "src": "/viewer",
      "dest": "/frontend/viewer.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "cleanUrls": true
}